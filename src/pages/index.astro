---
// airdb.id — 统一身份平台宣传首页（纯静态展示：能力、核验即弃、接入方式、路线图）。
import ProductLayout from "../layouts/ProductLayout.astro";
import {
  CAPABILITIES,
  STATUS_LABEL,
  VERIFY_STEPS,
  VERIFY_KEEP,
  VERIFY_DISCARD,
  ROADMAP,
  ENVIRONMENTS,
  CONSUMERS,
  SSO_URL,
  GITHUB_URL,
} from "../config/site";

const STATS = [
  { value: "OIDC / 2.1", label: "标准协议 · OpenID Connect + OAuth 2.1" },
  { value: "1 个账号", label: "通行 BBS、XAdmin 与全线 airdb 服务" },
  { value: "0 份影像", label: "证件核验即弃 · 只留结果与哈希" },
  { value: "2 套环境", label: "国内 id.airdb.net · 海外 airdb.id" },
];

// 代码示例用 set:html 渲染，避免 Astro 模板对花括号的转义负担。
const CODE_SAMPLES = [
  {
    key: "discovery",
    label: "Discovery",
    html: `<span class="t-dim">$</span> curl https://airdb.id/.well-known/openid-configuration

<span class="t-dim">{</span>
  <span class="t-key">"issuer"</span>:                 <span class="t-str">"https://airdb.id"</span>,
  <span class="t-key">"authorization_endpoint"</span>: <span class="t-str">"https://airdb.id/oauth/authorize"</span>,
  <span class="t-key">"token_endpoint"</span>:         <span class="t-str">"https://airdb.id/oauth/token"</span>,
  <span class="t-key">"jwks_uri"</span>:               <span class="t-str">"https://airdb.id/oauth/jwks"</span>,
  <span class="t-key">"scopes_supported"</span>:       [<span class="t-str">"openid"</span>, <span class="t-str">"profile"</span>, <span class="t-str">"email"</span>],
  <span class="t-key">"code_challenge_methods_supported"</span>: [<span class="t-str">"S256"</span>]
<span class="t-dim">}</span>`,
  },
  {
    key: "authorize",
    label: "Authorize",
    html: `<span class="t-kw">GET</span> /oauth/authorize
    ?client_id=<span class="t-str">bbs-airdb-net</span>
    &amp;response_type=<span class="t-str">code</span>
    &amp;scope=<span class="t-str">openid profile</span>
    &amp;redirect_uri=<span class="t-str">https://bbs.airdb.net/auth/callback</span>
    &amp;code_challenge=<span class="t-str">E9Melhoa…OT41gw</span>   <span class="t-dim"># PKCE · S256，强制</span>
    &amp;state=<span class="t-str">af0ifjsldkj</span>

<span class="t-dim">302 → https://bbs.airdb.net/auth/callback?code=…&amp;state=…</span>`,
  },
  {
    key: "token",
    label: "Token",
    html: `<span class="t-kw">POST</span> /oauth/token
    grant_type=<span class="t-str">authorization_code</span>
    code=<span class="t-str">SplxlOBeZQQYbYS6WxSbIA</span>
    code_verifier=<span class="t-str">dBjftJeZ4CVP…</span>

<span class="t-dim">{</span>
  <span class="t-key">"access_token"</span>:  <span class="t-str">"eyJhbG…"</span>,  <span class="t-dim"># JWT · 短时效</span>
  <span class="t-key">"refresh_token"</span>: <span class="t-str">"v1.MjAy…"</span>, <span class="t-dim"># 旋转 · 一次一换</span>
  <span class="t-key">"id_token"</span>:      <span class="t-str">"eyJhbG…"</span>
<span class="t-dim">}</span>`,
  },
];
---

<ProductLayout
  title="airdb.id — 统一身份平台 · 一个身份，通行所有 airdb 服务"
  description="airdb.id 是 airdb 体系的统一身份平台：OIDC / OAuth 2.1 单点登录、Passkey 多因素、审计风控与零信任接入。实名核验坚持「核验即弃」——只留结果与哈希，不留证件影像。"
  path="/"
>
  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-field" aria-hidden="true"></div>
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow reveal">airdb.id · 统一身份平台</p>
        <h1 class="reveal">
          一个身份，<br />
          <span class="ital">通行所有</span><br />
          airdb 服务。
        </h1>
        <p class="lede reveal">
          airdb.id 是 airdb 体系的用户身份中枢：OIDC / OAuth 2.1 单点登录，
          Passkey 多因素，零信任接入。实名核验坚持「核验即弃」——
          证件是用来核验的，不是用来收藏的。
        </p>
        <div class="hero-actions reveal">
          <a class="btn btn-solid" href={SSO_URL} rel="noopener">登录 airdb ID</a>
          <a class="btn btn-ghost" href="#verify">了解核验即弃</a>
        </div>
        <p class="hero-note reveal">
          平台建设中 · 现行入口 <span class="mono">sso.airdb.dev</span> · 国内环境 <span class="mono">id.airdb.net</span>
        </p>
      </div>

      <div class="id-card-wrap reveal">
        <figure class="id-card" aria-label="airdb ID 示例证件卡：只保存核验结果与哈希，不保存证件影像">
          <figcaption class="id-card-head">
            <span class="crest" aria-hidden="true">❖</span>
            <span class="id-card-title">airdb identity</span>
            <span class="id-card-sub">SPECIMEN · 样本</span>
          </figcaption>
          <div class="id-card-body">
            <div class="id-photo" aria-hidden="true">id</div>
            <dl class="id-fields">
              <div class="id-field">
                <dt>持有人 / Holder</dt>
                <dd>示例 · SPECIMEN</dd>
              </div>
              <div class="id-field">
                <dt>签发方 / Issuer</dt>
                <dd class="mono">id.airdb.net</dd>
              </div>
              <div class="id-field">
                <dt>证件号 / ID No.</dt>
                <dd class="mono redacted">hmac:8f3c…e21a</dd>
              </div>
              <div class="id-field">
                <dt>凭据 / Credential</dt>
                <dd>Passkey · 已启用</dd>
              </div>
              <div class="id-field">
                <dt>实名状态 / Status</dt>
                <dd class="ok">已核验 ✓</dd>
              </div>
              <div class="id-field">
                <dt>证件影像 / Image</dt>
                <dd class="redacted">未留存 —</dd>
              </div>
            </dl>
          </div>
          <div class="mrz" aria-hidden="true">
            ID&lt;AIRDB&lt;SPECIMEN<span>&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;</span><br />
            8F3C21E7<span>&lt;&lt;</span>VERIFIED<span>&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;</span>04
          </div>
          <svg class="id-stamp" viewBox="0 0 132 132" aria-hidden="true">
            <defs>
              <path id="stamp-arc" d="M 66,66 m -45,0 a 45,45 0 1,1 90,0 a 45,45 0 1,1 -90,0" />
            </defs>
            <circle cx="66" cy="66" r="62" fill="none" stroke="currentColor" stroke-width="3.5" />
            <circle cx="66" cy="66" r="55" fill="none" stroke="currentColor" stroke-width="1.2" />
            <text
              font-size="10"
              letter-spacing="2.1"
              fill="currentColor"
              style="font-family: var(--mono); text-transform: uppercase;"
            >
              <textPath href="#stamp-arc">verified · not retained · airdb.id ·</textPath>
            </text>
            <text
              x="66" y="62" text-anchor="middle" font-size="16" fill="currentColor"
              style="font-family: var(--serif); font-weight: 600;"
            >已核验</text>
            <text
              x="66" y="84" text-anchor="middle" font-size="16" fill="currentColor"
              style="font-family: var(--serif); font-weight: 600;"
            >未留存</text>
          </svg>
        </figure>
        <p class="spec-note">▲ 示例样本：我们保存的全部，就是这张卡上的东西。</p>
      </div>
    </div>

    <div class="shell">
      <dl class="stat-strip reveal">
        {STATS.map((s) => (
          <div class="stat">
            <dt>{s.value}</dt>
            <dd>{s.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ============ 平台能力 ============ -->
  <section class="platform" id="capabilities">
    <div class="shell">
      <header class="section-head">
        <p class="eyebrow">平台能力</p>
        <h2>六件事，<span class="ital">一个身份</span>。</h2>
        <p class="section-lede">
          登录、账号、多因素、审计、实名、零信任——用户身份相关的事都归这里，
          业务系统不再各自管用户。状态如实标注：没上线，就写规划中。
        </p>
      </header>
      <div class="cap-grid">
        {CAPABILITIES.map((c) => (
          <article class="cap-card">
            <span class="cap-top">
              <span class="cap-no">{c.no}</span>
              <span>
                <span class:list={["cap-status", `is-${c.status}`]}>{STATUS_LABEL[c.status]}</span>
                <span class="cap-phase">{c.phase}</span>
              </span>
            </span>
            <h3>{c.title}</h3>
            <p>{c.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 核验即弃 ============ -->
  <section class="verify" id="verify">
    <div class="shell verify-grid">
      <div class="verify-copy">
        <p class="eyebrow eyebrow-light">核验即弃 · Verify &amp; Discard</p>
        <h2>证件用来核验，<br /><span class="ital">不用来收藏</span>。</h2>
        <p>
          身份证、护照、工作证——这类敏感证件，对平台来说<strong>存下来就是负债</strong>。
          泄露一次，用户没法像改密码一样换一张身份证。
        </p>
        <p>
          所以 airdb.id 把实名做成一条<strong>通道</strong>而不是一个仓库：
          证件只在核验那一刻经过我们，比对完成即丢弃，系统里留下的只有结果、哈希与时间。
        </p>
        <p>
          业务系统则更简单：只能问「这个人是否已实名」，得到一个布尔值，
          <strong>永远拿不到证件数据</strong>——因为我们自己也没有。
        </p>
        <p class="verify-note">
          注：依照《个人信息保护法》，证件信息属于敏感个人信息——单独同意、最小化使用、
          国内数据境内留存。「核验即弃」是把合规写进架构，而不是写进承诺。
        </p>
      </div>
      <div>
        <div class="flow">
          {VERIFY_STEPS.map((s) => (
            <div class="flow-step">
              <span class="flow-no" aria-hidden="true">{s.no}</span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.copy}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="keep-discard">
          <div class="kd-col kd-keep">
            <span class="kd-tag">我们保存的</span>
            <ul>
              {VERIFY_KEEP.map((i) => (
                <li>
                  <span class="kd-field">{i.field}</span>
                  <span class="kd-note">{i.note}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="kd-col kd-discard">
            <span class="kd-tag">我们不保存的</span>
            <ul>
              {VERIFY_DISCARD.map((i) => (
                <li>
                  <span class="kd-field">{i.field}</span>
                  <span class="kd-note">{i.note}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ 开发者接入 ============ -->
  <section id="developers">
    <div class="shell dev-grid">
      <div>
        <p class="eyebrow">开发者接入</p>
        <h2>标准 OIDC，<span class="ital">不发明轮子</span>。</h2>
        <p class="section-lede">
          任何支持 OpenID Connect 的语言和框架都能直接接入，
          三个端点走完标准授权码流程，不需要学习私有协议。
        </p>
        <ul class="dev-points">
          <li><strong>强制 PKCE</strong>，不提供隐式流——按 OAuth 2.1 的姿势来。</li>
          <li><strong>短时效 Access Token</strong>，Refresh Token 旋转，一次一换。</li>
          <li><strong>实名查询只返回布尔与等级</strong>，业务方永远接触不到证件数据。</li>
          <li><strong>Webhook</strong> 推送注册、注销与风险事件，业务侧无需轮询。</li>
        </ul>
      </div>
      <div class="code-panel">
        <div class="code-tabs" role="tablist" aria-label="OIDC 接入示例">
          {CODE_SAMPLES.map((s, i) => (
            <button
              role="tab"
              id={`tab-${s.key}`}
              aria-controls={`panel-${s.key}`}
              aria-selected={i === 0 ? "true" : "false"}
              class:list={[i === 0 && "active"]}
              data-code-tab={s.key}
            >{s.label}</button>
          ))}
        </div>
        {CODE_SAMPLES.map((s, i) => (
          <pre
            role="tabpanel"
            id={`panel-${s.key}`}
            aria-labelledby={`tab-${s.key}`}
            class:list={["code-sample", i === 0 && "active"]}
            data-code-panel={s.key}
            set:html={s.html}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 路线图 ============ -->
  <section class="roadmap" id="roadmap">
    <div class="shell">
      <header class="section-head">
        <p class="eyebrow">路线图</p>
        <h2>四步走，<span class="ital">不许愿</span>。</h2>
        <p class="section-lede">
          每一期都是可独立交付的能力：先把 SSO 落地，再做加固，然后才轮到实名与零信任。
        </p>
      </header>
      <div class="phase-grid">
        {ROADMAP.map((p) => (
          <div class:list={["phase", `is-${p.status}`]}>
            <span class="phase-key">{p.key}</span>
            <h3>{p.title}</h3>
            <p>{p.copy}</p>
            <span class:list={["cap-status", "phase-status", `is-${p.status}`]}>{STATUS_LABEL[p.status]}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ 环境与接入方 ============ -->
  <section id="network">
    <div class="shell">
      <header class="section-head">
        <p class="eyebrow">环境与接入方</p>
        <h2>两套环境，<span class="ital">一一对应</span>。</h2>
        <p class="section-lede">
          .id 与 .dev 一样无法 ICP 备案，所以国内、海外各一套，账号互通；
          国内用户的敏感数据只落国内节点。
        </p>
      </header>

      <div class="env-grid">
        {ENVIRONMENTS.map((e) => (
          <div class="env-card">
            <span class="env-tag">{e.tag}</span>
            <h3>{e.host}</h3>
            <p>{e.copy}</p>
          </div>
        ))}
      </div>

      <div class="ledger">
        <div class="ledger-head">
          <h3>接入方台账</h3>
          <span class="mono">状态如实标注 · 缺漏请提 issue</span>
        </div>
        <ul class="sys-list">
          {CONSUMERS.map((c) => (
            <li>
              <a href={c.url} rel="noopener">
                <span class="sys-name">{c.name}</span>
                <span class="sys-host">{c.host}</span>
                <span class:list={["sys-badge", `is-${c.status}`]}>{STATUS_LABEL[c.status]}</span>
                <span class="sys-arrow" aria-hidden="true">↗</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="cta-band">
    <div class="shell cta-inner">
      <h2>让系统<span class="ital">少管一件事</span>。</h2>
      <p>把登录和用户交给 airdb.id，业务只做业务。接入排期、能力建议、台账缺漏——都欢迎提 issue。</p>
      <div class="hero-actions">
        <a class="btn btn-paper" href={GITHUB_URL} rel="noopener">GitHub 提 Issue</a>
        <a class="btn btn-ghost-light" href={SSO_URL} rel="noopener">登录 airdb ID</a>
      </div>
    </div>
  </section>

  <style>
    /* 中文标题不用合成斜体，保留强调色即可 */
    h1 .ital,
    h2 .ital {
      font-style: normal;
    }
  </style>

  <script>
    // 代码示例 tab 切换
    document.querySelectorAll<HTMLButtonElement>("[data-code-tab]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const key = btn.dataset.codeTab;
        document.querySelectorAll("[data-code-tab]").forEach((b) => {
          b.classList.toggle("active", b === btn);
          b.setAttribute("aria-selected", String(b === btn));
        });
        document.querySelectorAll<HTMLElement>("[data-code-panel]").forEach((p) => {
          p.classList.toggle("active", p.dataset.codePanel === key);
        });
      });
    });

    // 滚动渐显
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.01, rootMargin: "0px 0px -8% 0px" }
    );
    document
      .querySelectorAll(".cap-card, .section-head, .flow-step, .kd-col, .phase, .env-card, .ledger, .verify-copy")
      .forEach((el) => {
        el.classList.add("will-reveal");
        observer.observe(el);
      });
  </script>
</ProductLayout>
